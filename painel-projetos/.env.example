# =====================================================================
# PAINEL DE PROJETOS — variáveis de ambiente (exemplo)
# ---------------------------------------------------------------------
# Copie este arquivo para ".env" e preencha com os valores do seu
# projeto. A DEMO funciona 100% offline com dados mock (public/data.js),
# então estas variáveis só são necessárias se você ligar um backend real.
# NUNCA versione o arquivo ".env" com credenciais reais.
# =====================================================================

# URL do projeto Supabase (ou outro backend)
SUPABASE_URL=https://demo.exemplo.dev

# Chave pública (anon/publishable) — segura para uso no front-end
SUPABASE_KEY=coloque-sua-chave-publica-aqui
