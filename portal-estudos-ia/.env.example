# ===== Front-end (index.html) — chave PÚBLICA (anon), pode ir no cliente =====
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=coloque-sua-chave-anon-publica

# ===== Backend (Cloudflare Pages Function /api/gerar) — SECRETS =====
# Configure com: wrangler pages secret put NOME
SB_URL=https://SEU-PROJETO.supabase.co
SB_SERVICE_KEY=coloque-sua-service-role-key   # NUNCA exponha isto no cliente
ELEVEN_KEY=                                   # opcional (TTS de áudio); vazio = áudio desligado
