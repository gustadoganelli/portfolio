# ============================================================
# Variaveis de ambiente - Conciliacao Bancaria (DEMO)
# Copie para .env e preencha com seus proprios valores.
# Todos os valores abaixo sao FICTICIOS / placeholders.
# ============================================================

# --- API do Banco (extrato de pagamentos) ---
BANCO_BASE_URL=https://demo.exemplo.dev/banco
BANCO_CLIENT_ID=seu-client-id-aqui
BANCO_CLIENT_SECRET=seu-client-secret-aqui
BANCO_AGENCIA=0000
BANCO_CONTA=0000-0

# --- API da Adquirente / Maquininha (vendas em cartao) ---
ADQUIRENTE_BASE_URL=https://demo.exemplo.dev/adquirente
# Base64 de "client_id:client_secret" (fluxo OAuth password)
ADQUIRENTE_BASIC_AUTH=Y2xpZW50OnNlY3JldA==
ADQUIRENTE_USERNAME=joao@exemplo.com
ADQUIRENTE_PASSWORD=sua-senha-aqui
ADQUIRENTE_MERCHANT_NUMBER=00000000

# --- Banco de dados do ERP (SQL Server) ---
# Configurado como credencial n8n (microsoftSql), nao via .env.
# Veja README "Como rodar".
ERP_CODIGO_CONTA=0000-0

# --- Microsoft Graph (upload no SharePoint) ---
MS_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_SECRET=seu-secret-graph-aqui
SHAREPOINT_SITE_ID=demo.sharepoint.com,00000000-0000-0000-0000-000000000000,00000000-0000-0000-0000-000000000000

# --- Notificacao (Teams Incoming Webhook) ---
TEAMS_WEBHOOK_URL=https://demo.exemplo.dev/webhook/teams
