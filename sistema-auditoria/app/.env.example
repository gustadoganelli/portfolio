# Configuracao do backend (exemplo).
# Copie para .env e preencha com os valores do seu projeto.
# Sem estas variaveis, o app roda em MODO MOCK (dados ficticios embutidos).

VITE_API_URL={{ENV_API_URL}}
VITE_API_KEY={{ENV_API_KEY}}

# Exemplo de valores ficticios:
# VITE_API_URL=https://demo.exemplo.dev
# VITE_API_KEY=chave-publica-de-exemplo
