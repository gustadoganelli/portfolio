# ==========================================================================
# Variáveis de ambiente — Sistema de Registro de Doações (DEMO)
# Copie este arquivo para `.env.local` e preencha com seus valores.
# NUNCA versione o arquivo `.env.local`.
# ==========================================================================

# --- Supabase (cliente / browser) -----------------------------------------
# Encontre em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL={{NEXT_PUBLIC_SUPABASE_URL}}
NEXT_PUBLIC_SUPABASE_ANON_KEY={{NEXT_PUBLIC_SUPABASE_ANON_KEY}}

# --- URL pública do app (usada em links de notificação) -------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Somente servidor (NÃO use o prefixo NEXT_PUBLIC) ---------------------
# service_role é usado apenas em scripts administrativos/seed locais.
# NÃO é necessário para o app rodar — o app usa a sessão do usuário (RLS).
SUPABASE_SERVICE_ROLE_KEY={{SUPABASE_SERVICE_ROLE_KEY}}
SUPABASE_PROJECT_ID={{SUPABASE_PROJECT_ID}}
