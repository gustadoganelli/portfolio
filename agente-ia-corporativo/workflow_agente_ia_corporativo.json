    },
    "Consultar Status": {
      "main": [[{ "node": "Formatar Status", "type": "main", "index": 0 }]]
    },
    "Formatar Status": {
      "main": [[{ "node": "Resposta Final (Webhook)", "type": "main", "index": 0 }]]
    },
    "Atualizar Cadastro": {
      "main": [[{ "node": "Responder (Atualizacao)", "type": "main", "index": 0 }]]
    },
