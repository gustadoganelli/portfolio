    },
    "Criar Tarefa (Gestor de Tarefas)": {
      "main": [[{ "node": "Responder (Abertura)", "type": "main", "index": 0 }]]
    },
    "Responder (Abertura)": {
      "main": [[{ "node": "Resposta Final (Webhook)", "type": "main", "index": 0 }]]
    },
    "Consultar Minhas Solicitacoes": {
      "main": [[{ "node": "Formatar Minhas Solicitacoes", "type": "main", "index": 0 }]]
    },
    "Formatar Minhas Solicitacoes": {
