    },
    "Executar Acao?": {
      "main": [
        [{ "node": "Rotear por Acao", "type": "main", "index": 0 }],
        [{ "node": "Responder (so informacao)", "type": "main", "index": 0 }]
      ]
    },
    "Rotear por Acao": {
      "main": [
        [{ "node": "Normalizar Dados", "type": "main", "index": 0 }],
        [{ "node": "Consultar Minhas Solicitacoes", "type": "main", "index": 0 }],
        [{ "node": "Consultar Status", "type": "main", "index": 0 }],
        [{ "node": "Atualizar Cadastro", "type": "main", "index": 0 }]
      ]
    },
